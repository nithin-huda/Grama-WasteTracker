<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F5F2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════════ HERO HEADER ═══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_green"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="48dp">

            <!-- Top row: welcome + language toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Day! 😊"
                        android:fontFamily="sans-serif"
                        android:textSize="14sp"
                        android:textColor="#CCFFFFFF" />

                    <TextView
                        android:id="@+id/tvWelcomeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_resident"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="22sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLanguageToggle"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/lang_toggle_text"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    app:strokeColor="#AAFFFFFF"
                    app:cornerRadius="18dp" />
            </LinearLayout>

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_subtitle"
                android:fontFamily="sans-serif"
                android:textSize="13sp"
                android:textColor="#B3FFFFFF"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- ═══════════════ FLOATING CARDS SECTION ═══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-44dp"
            android:paddingHorizontal="16dp">

            <!-- TRACTOR STATUS CARD (full width, overlaps hero) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTractorStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Green icon circle -->
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="16dp">
                        <View
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/shape_dot_green_circle" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🚜"
                            android:textSize="24sp" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COLLECTION TRUCK"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="10sp"
                            android:textColor="#9E9E9E"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvHomeTractorStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/waiting_signal"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="17sp"
                            android:textColor="#1B5E20"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tvHomeTractorDist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenMap"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Track"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="13sp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#2E7D32" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- QUICK ACTIONS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Report Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardReport"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFF8F0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp">
                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/shape_orange_circle" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="⚠️"
                                android:textSize="22sp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Report"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="13sp"
                            android:textColor="#BF360C"
                            android:gravity="center" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blackspot"
                            android:fontFamily="sans-serif"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Live Map Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLiveMap"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#F0F8F0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp">
                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/shape_dot_green_circle" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="📍"
                                android:textSize="22sp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live Map"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="13sp"
                            android:textColor="#1B5E20"
                            android:gravity="center" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Track truck"
                            android:fontFamily="sans-serif"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Guide Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGuide"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#F0F4FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp">
                            <View
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/shape_blue_circle" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="📋"
                                android:textSize="22sp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Guide"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="13sp"
                            android:textColor="#1565C0"
                            android:gravity="center" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Segregation"
                            android:fontFamily="sans-serif"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- COLLECTION SCHEDULE CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅"
                            android:textSize="18sp"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/collection_schedule"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="16sp"
                            android:textColor="#212121" />
                    </LinearLayout>

                    <!-- Wet Waste Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/shape_schedule_row"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/wet_waste_label"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp"
                            android:textColor="#2E7D32" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_wet"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="#388E3C" />
                    </LinearLayout>

                    <!-- Dry Waste Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/shape_schedule_row"
                        android:paddingHorizontal="14dp"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/dry_waste_label"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp"
                            android:textColor="#1565C0" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_dry"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="#1976D2" />
                    </LinearLayout>

                    <!-- Plastic Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/shape_schedule_row"
                        android:paddingHorizontal="14dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plastic_waste_label"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="14sp"
                            android:textColor="#E65100" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_plastic"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="#F57C00" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TIP CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E8F5E9">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡"
                        android:textSize="20sp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DID YOU KNOW?"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="10sp"
                            android:textColor="#2E7D32"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notif_tip"
                            android:fontFamily="sans-serif"
                            android:textSize="13sp"
                            android:textColor="#33691E" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>