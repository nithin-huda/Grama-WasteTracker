<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="🏛️ Panchayat Admin Panel"
        app:titleTextColor="?attr/colorOnPrimary" />

    <!-- Report count badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:background="?attr/colorPrimaryContainer">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Blackspot Reports"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_report_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnPrimaryContainer" />
    </LinearLayout>

    <!-- Map — top half -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/admin_map_container"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant" />

    <!-- Report list header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  📋 Report List"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:paddingVertical="8dp"
        android:background="?attr/colorSurfaceVariant" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_no_reports"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No blackspot reports yet"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone" />

    <!-- Report list — bottom half -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_reports"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>
